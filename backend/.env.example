# backend/.env.example  — copy to backend/.env and adjust
DOWNLOAD_DIR=/downloads
DATABASE_URL=sqlite+aiosqlite:////app/data/downloads.db
MAX_CONCURRENT_DOWNLOADS=3
AUDIO_FORMAT=mp3
# AUDIO_QUALITY is deprecated - audio is always downloaded at highest quality
AUDIO_QUALITY=0
DEBUG=false
# Comma-separated origins or * for all
CORS_ORIGINS=*